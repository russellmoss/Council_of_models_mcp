# Get your OpenAI API key from https://platform.openai.com/api-keys
# Optional if you use Codex CLI instead (codex login)
OPENAI_API_KEY=sk-your-key-here

# Get your Google Gemini API key from https://aistudio.google.com/apikey
# Either GEMINI_API_KEY or GOOGLE_API_KEY works — set one of them
GEMINI_API_KEY=your-key-here

# Codex CLI does NOT need an env var — it uses `codex login` for auth.
# Install: npm i -g @openai/codex && codex login
